{
  "meta": {
    "company": "Sofka Technologies",
    "logoText": "Jarvis ElRepo",
    "logoUrl": "https://github.com/javiermontano-sofka/sofka-discovery-framework-public/blob/main/sofka_logo.jpg?raw=true",
    "logoAlt": "Sofka Technologies",
    "copyright": "Jarvis ElRepo de Sofka Technologies. Release 1.0.1",
    "language": "es",
    "designSystem": "ElRepo Dark DS",
    "bundleVersion": "10.1",
    "releaseLabel": "1.0.1"
  },
  "colors": {
    "brand": "#F26322",
    "gold": "#FFD700",
    "blue": "#60A5FA",
    "green": "#22C55E",
    "red": "#EF4444",
    "amber": "#F59E0B",
    "bg0": "#080808",
    "bg1": "#111111",
    "bg2": "#181818",
    "bg3": "#222222",
    "t1": "#F0F0F0",
    "t2": "#B8B8B8",
    "t3": "#888888",
    "border": "#2A2A2A",
    "borderLight": "#3A3A3A"
  },
  "typography": {
    "fontBody": "system-ui, -apple-system, sans-serif",
    "fontMono": "ui-monospace, SFMono-Regular, monospace"
  },
  "radius": {
    "sm": "6px",
    "md": "10px",
    "lg": "14px"
  },
  "layout": {
    "maxWidth": "960px"
  },
  "cssCustomPropertyMap": {
    "--brand": "#F26322",
    "--gold": "#FFD700",
    "--blue": "#60A5FA",
    "--green": "#22C55E",
    "--red": "#EF4444",
    "--amber": "#F59E0B",
    "--bg0": "#080808",
    "--bg1": "#111111",
    "--bg2": "#181818",
    "--bg3": "#222222",
    "--t1": "#F0F0F0",
    "--t2": "#B8B8B8",
    "--t3": "#888888",
    "--border": "#2A2A2A",
    "--border-light": "#3A3A3A",
    "--font-body": "system-ui, -apple-system, sans-serif",
    "--font-mono": "ui-monospace, SFMono-Regular, monospace",
    "--radius-sm": "6px",
    "--radius-md": "10px",
    "--radius-lg": "14px",
    "--max-w": "960px"
  },
  "components": {
    "gauge": { "size": "80px", "innerSize": "56px", "trackColor": "var(--bg3)", "fillColor": "var(--brand)" },
    "progressBar": { "height": "8px", "trackColor": "var(--bg3)", "fillGradient": "linear-gradient(90deg, var(--brand), var(--gold))" },
    "trafficLight": { "dotSize": "20px", "glowRadius": "12px", "states": ["verde", "amarillo", "rojo"] },
    "dashboard": { "minCardWidth": "160px", "cardBg": "var(--bg2)", "cardBorder": "var(--border)" },
    "promptBlock": { "bg": "var(--bg2)", "fontFamily": "var(--font-mono)", "fontSize": "0.82rem" }
  },
  "infographic": {
    "nanoBananaUrl": "https://imagen.sofka.com.co",
    "brandPalette": ["#F26322", "#FFD700", "#60A5FA", "#22C55E", "#EF4444"],
    "darkBackground": "#080808",
    "layoutStyle": "corporate dashboard, data-rich, system fonts"
  },
  "ghostMenu": {
    "version": "v1.0.1",
    "options": 16,
    "surfaceAware": true,
    "surfaces": ["gemini", "claude", "generic"]
  }
}
